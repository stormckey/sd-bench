{
  "experiment_name": "wildchat-qwen8b-draft-translate",
  "method": "draft_speculative",
  "target_model": "Qwen/Qwen3-8B",
  "draft_model": "Qwen/Qwen3-0.6B",
  "prompt_source": "wildchat_hf",
  "prompt_path": "data/prompts/sample_prompts.jsonl",
