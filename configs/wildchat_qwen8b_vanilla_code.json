{
  "experiment_name": "wildchat-qwen8b-vanilla-code",
  "method": "autoregressive",
  "target_model": "Qwen/Qwen3-8B",
  "draft_model": null,
  "prompt_source": "wildchat_hf",
  "prompt_path": "data/prompts/sample_prompts.jsonl",
  "dataset_name": "allenai/WildChat",
  "dataset_split": "train",
  "dataset_language": "English",
  "dataset_streaming": true,
  "dataset_max_messages": 2,
  "dataset_min_user_chars": 30,
  "dataset_max_user_chars": 400,
  "dataset_include_keywords": [
    "code",
    "python",
    "function",
    "implement"
  ],
  "dataset_exclude_keywords": [
    "translate",
    "story",
    "poem",
    "roleplay"
  ],
  "enable_thinking": false,
  "batch_size": 1,
  "max_new_tokens": 1024,
  "do_sample": false,
  "temperature": 0,
  "top_p": 1,
  "torch_dtype": "bfloat16",
  "gpu": "L40S",
  "seed": 1234,
  "limit": 10,
  "notes": "Filtered WildChat slice focused on short coding prompts."
}
